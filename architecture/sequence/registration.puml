@startuml

autonumber

actor Client as client
participant "Individuals API" as api
participant "Person Service" as person
participant "Person Database" as personDb
participant Keycloak as keycloak


client -> api: POST \n /v1/auth/registration \n application/json
api -> api: Валидация запроса

alt #FFCCCC Ошибка валидации
api -> api: Валидация запроса
api --> client: status: 400 \n application\json \n error, status
end

api -> person: POST \n /v1/individuals \n Authorization: Bearer {service_token} \n application/json
person -> personDb: Сохранение данных \n статус: PENDING, filled: true
personDb --> person: userId
person --> api: status: 201 \n location: /v1/individuals/{userId}
api -> keycloak: POST \n /admin/realms/{realm}/users \n application\json \n email, password, userId
keycloak -> keycloak: Создание нового пользователя
keycloak --> api: status: 201
api -> person: POST \n /v1/individuals/{userId}/active \n Authorization: Bearer {service_token}
person -> personDb: Сохранение данных \n status: ACTIVE, verified_at: now
personDb --> person: Подтверждение обновления статуса
person --> api: status: 200

alt #FFCCCC Не удалось создать пользователя в Keycloak
keycloak -> keycloak: Создание нового пользователя
keycloak --> api: status: 4xx, 5xx \n application/json
api -> api: Обработка ошибки
api -> person: POST \n /v1/individuals/{userId}/purge
person -> personDb: Удаление "под чистую" пользователя по userId
personDb --> person: Подтверждение удаления
person --> api: status: 204
api --> client: status: 4xx, 5xx \n application/json \n error, status
end

api -> keycloak: POST \n /realms/{realm}/protocol/openid-connect/token \n application/x-www-form-urlencoded \n grant_type: password
keycloak -> keycloak: Аутентификация / Авторизация
keycloak --> api: application/json \n access_token, refresh_token ...
api --> client: application/json \n access_token, refresh_token ...

@enduml